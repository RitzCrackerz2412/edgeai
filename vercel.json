{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/cron/live",      "schedule": "* * * * *"    },
    { "path": "/api/cron/injuries",  "schedule": "*/5 * * * *"  },
    { "path": "/api/cron/odds",      "schedule": "*/5 * * * *"  },
    { "path": "/api/cron/stats",     "schedule": "*/15 * * * *" },
    { "path": "/api/cron/rankings",  "schedule": "0 * * * *"    },
    { "path": "/api/cron/refresh",   "schedule": "0 0 * * *"    },
    { "path": "/api/cron/predict",   "schedule": "0 6 * * *"    },
    { "path": "/api/cron/validate",  "schedule": "0 12 * * *"   }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff"       },
        { "key": "X-Frame-Options",        "value": "DENY"          },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" }
      ]
    }
  ]
}
