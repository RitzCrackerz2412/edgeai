{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/cron/live",      "schedule": "0 1 * * *"    },
    { "path": "/api/cron/injuries",  "schedule": "0 2 * * *"    },
    { "path": "/api/cron/odds",      "schedule": "0 3 * * *"    },
    { "path": "/api/cron/stats",     "schedule": "0 4 * * *"    },
    { "path": "/api/cron/rankings",  "schedule": "0 5 * * *"    },
    { "path": "/api/cron/refresh",   "schedule": "0 0 * * *"    },
    { "path": "/api/cron/predict",   "schedule": "0 6 * * *"    },
    { "path": "/api/cron/validate",  "schedule": "0 7 * * *"    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff"       },
        { "key": "X-Frame-Options",        "value": "DENY"          },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" }
      ]
    }
  ]
}
